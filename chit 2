-- Step 2: Create Borrower Table
CREATE TABLE Borrower (
    Rollin NUMBER(5),
    Name VARCHAR2(20),
    DateofIssue DATE,
    NameofBook VARCHAR2(30),
    Status VARCHAR2(1)
);

-- Step 3: Create Fine Table
CREATE TABLE Fine (
    Roll_no NUMBER(5),
    Date1 DATE,
    Amt NUMBER(10)
);

