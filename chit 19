---------------------------------------------------
-- i. Modify database so company ABC is now in Pune
---------------------------------------------------
UPDATE Company
SET city = 'Pune'
WHERE cname = 'ABC';

-- Display Updated Company Table
SELECT * FROM Company;

---------------------------------------------------
-- ii. Give all managers of Mbank a raise:
-- Salary > 20000 => 3%
-- Otherwise => 10%
---------------------------------------------------
UPDATE Works
SET sal = CASE
            WHEN sal > 20000 THEN sal + (sal * 0.03)
            ELSE sal + (sal * 0.10)
          END
WHERE cname = 'Mbank';

-- Display Updated Works Table
SELECT * FROM Works
WHERE cname = 'Mbank';

---------------------------------------------------
-- iii. Names of employees who work in Bosch in Pune
---------------------------------------------------
SELECT ename
FROM Works
WHERE cname = 'Bosch'
AND emp_id IN (
    SELECT emp_id
    FROM Emp
    WHERE city = 'Pune'
);

---------------------------------------------------
-- iv. Delete records of SBC Company employees
-- whose salary > 50000
---------------------------------------------------
DELETE FROM Works
WHERE cname = 'SBC Company'
AND sal > 50000;

-- Display Updated Works Table
SELECT * FROM Works;

---------------------------------------------------
-- Step 12: Exit MySQL
---------------------------------------------------
EXIT;
