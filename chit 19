-- Step 1: Open MySQL
mysql -u root -p

-- Step 2: Create Database
CREATE DATABASE CompanyDB;

-- Step 3: Use Database
USE CompanyDB;

-- Step 4: Create Emp Table
CREATE TABLE Emp (
    emp_id INT,
    ename VARCHAR(20),
    street VARCHAR(30),
    city VARCHAR(20)
);

-- Step 5: Create Company Table
CREATE TABLE Company (
    c_id INT,
    cname VARCHAR(20),
    city VARCHAR(20)
);

-- Step 6: Create Works Table
CREATE TABLE Works (
    emp_id INT,
    c_id INT,
    ename VARCHAR(20),
    cname VARCHAR(20),
    sal INT
);

-- Step 7: Create Manager Table
CREATE TABLE Manager (
    mgr_id INT,
    mgrname VARCHAR(20)
);

