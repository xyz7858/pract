-- Step 1: Open MySQL Terminal
mysql -u root -p

-- Step 2: Create Database
CREATE DATABASE UniversityDB;

-- Step 3: Use Database
USE UniversityDB;

-- Step 4: Create Student Table
CREATE TABLE student (
    S_ID INT,
    name VARCHAR(20),
    dept_name VARCHAR(20),
    tot_cred INT
);

-- Step 5: Create Instructor Table
CREATE TABLE instructor (
    T_ID INT,
    name VARCHAR(20),
    dept_name VARCHAR(20),
    salary INT
);

-- Step 6: Create Course Table
CREATE TABLE course (
    course_id INT,
    title VARCHAR(20),
    dept_name VARCHAR(20),
    credits INT
);

-- Step 7: Create Teaches Table
CREATE TABLE teaches (
    T_ID INT,
    course_id INT,
    sec_id INT,
    semester VARCHAR(20),
    year INT
);

