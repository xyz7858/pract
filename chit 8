---------------------------------------------------
-- i. Find names of instructors who taught courses semester wise
---------------------------------------------------
SELECT instructor.name, course.title, teaches.semester, teaches.year
FROM instructor
JOIN teaches
ON instructor.T_ID = teaches.T_ID
JOIN course
ON teaches.course_id = course.course_id
ORDER BY teaches.semester;

